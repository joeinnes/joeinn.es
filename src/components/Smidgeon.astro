---
import { marked } from "marked";
// A smidgeon normalised to a plain view model, so this renders identically
// whether the source is a PDS record or the local content collection.
export interface Props {
  smidgeon: { summary: string; body: string; created: Date | string };
}

const { smidgeon } = Astro.props;
---

<style>
  article {
    border-bottom: 1px solid var(--very-muted);
    & > div {
      color: var(--muted);
      font-size: 0.9em;
      margin-block-start: 0;
    }
  }
</style>
<article>
  <p>{smidgeon.summary}</p>
  {smidgeon.body && <div set:html={marked.parse(smidgeon.body)} />}
  <small>
    {
      new Date(smidgeon.created).toLocaleDateString("en-GB", {
        weekday: "short",
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    }
  </small>
</article>
