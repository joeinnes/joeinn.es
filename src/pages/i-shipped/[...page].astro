---
import GitHubLink from "../../components/GitHubLink.astro";
import Layout from "../../layouts/Default.astro";
import Nav from "../../components/NewNav.astro";
import { marked } from "marked";

import { getCollection, render, type CollectionEntry } from "astro:content";
import {
  fetchShipped,
  fetchShippedDigests,
  safe,
  type ShippedView,
  type ShippedDigestView,
} from "../../lib/pds";

// A shipped contribution normalised across both sources. PDS records carry a
// Markdown `markdown` body; local content entries carry an `entry` we render as
// MDX. Exactly one of the two is set.
interface ShippedItem {
  summary: string;
  repo: string;
  prNumber: string;
  mergeDate: Date;
  entry?: CollectionEntry<"i-shipped">;
  markdown?: string | null;
}

// The latest digest, normalised the same way.
interface DigestVm {
  label: string;
  entry?: CollectionEntry<"shipped-digests">;
  markdown?: string | null;
}

// Prefer the PDS (es.joeinn.shipped) at build; fall back to the local content
// collection when the fetch fails OR returns nothing, so the build stays green
// throughout the migration. Sorted newest-first either way.
async function loadShippedItems(): Promise<ShippedItem[]> {
  const pds: ShippedItem[] = (await safe(fetchShipped(), [] as ShippedView[]))
    .filter((r) => r.mergedAt instanceof Date && !isNaN(r.mergedAt.getTime()))
    .map((r) => ({
      summary: r.summary,
      repo: r.repo,
      prNumber: r.prNumber,
      mergeDate: r.mergedAt,
      markdown: r.description,
    }));
  if (pds.length > 0) {
    return pds.sort((a, b) => b.mergeDate.getTime() - a.mergeDate.getTime());
  }

  const local: ShippedItem[] = (await getCollection("i-shipped"))
    .filter((item) => item.data?.mergeDate)
    .map((item) => ({
      summary: item.data.summary,
      repo: item.data.repo,
      prNumber: item.data.prNumber,
      mergeDate: item.data.mergeDate,
      entry: item,
    }));
  return local.sort((a, b) => b.mergeDate.getTime() - a.mergeDate.getTime());
}

// Latest digest (any period), from the PDS (es.joeinn.shippedDigest) with the
// same PDS-then-local fallback. Returns null when neither source has one.
async function loadLatestDigest(): Promise<DigestVm | null> {
  const pds = (await safe(fetchShippedDigests(), [] as ShippedDigestView[]))
    .filter((d) => d.endDate instanceof Date && !isNaN(d.endDate.getTime()))
    .sort((a, b) => b.endDate.getTime() - a.endDate.getTime());
  const latest = pds[0];
  if (latest) {
    return {
      label:
        latest.title ??
        latest.endDate.toLocaleDateString("en-GB", {
          month: "long",
          year: "numeric",
        }),
      markdown: latest.summary,
    };
  }

  const entry = (await getCollection("shipped-digests"))
    .filter((d) => d.data?.end)
    .sort((a, b) => (b.data.end?.getTime() ?? 0) - (a.data.end?.getTime() ?? 0))[0];
  if (!entry) return null;
  return {
    label:
      entry.data.title ??
      entry.data.end?.toLocaleDateString("en-GB", {
        month: "long",
        year: "numeric",
      }) ??
      "",
    entry,
  };
}

const ITEMS_PER_PAGE = 20;
const { page } = Astro.params;
const currentPage = page ? parseInt(page as string) : 1;

const sorted = await loadShippedItems();
const totalPages = Math.ceil(sorted.length / ITEMS_PER_PAGE);
const paginated = sorted.slice(
  (currentPage - 1) * ITEMS_PER_PAGE,
  currentPage * ITEMS_PER_PAGE,
);

const groupedByDate = paginated.reduce(
  (groups, item) => {
    const dateKey =
      item.mergeDate.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "long",
        year: "numeric",
      }) || "Unknown Date";

    if (!groups[dateKey]) {
      groups[dateKey] = [];
    }
    groups[dateKey].push(item);
    return groups;
  },
  {} as Record<string, ShippedItem[]>,
);

// Latest digest (any period) — shown as an intro summary on the first page only.
const digest = currentPage === 1 ? await loadLatestDigest() : null;
const DigestContent = digest?.entry ? (await render(digest.entry)).Content : null;
const digestHtml: string =
  digest && !digest.entry ? await marked.parse(digest.markdown ?? "") : "";
const digestLabel = digest?.label;

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 20;

  // Mirror the page body's source selection so the emitted page count matches
  // what actually renders: PDS when it has records, else the local collection.
  const pdsValid = (await safe(fetchShipped(), [] as ShippedView[])).filter(
    (r) => r.mergedAt instanceof Date && !isNaN(r.mergedAt.getTime()),
  );
  const shippedCount =
    pdsValid.length > 0
      ? pdsValid.length
      : (await getCollection("i-shipped")).filter((item) => item.data?.mergeDate)
          .length;
  const totalPages = Math.ceil(shippedCount / ITEMS_PER_PAGE);

  return [
    { params: { page: undefined } },
    ...Array.from({ length: totalPages }, (_, i) => ({
      params: { page: String(i + 1) },
    })),
  ];
}

const description =
  "Open source contributions from Joe Innes — a running log of merged pull requests and the projects they shipped to.";
---

<style>
  .digest {
    margin-block: calc(var(--layout-spacing) / 2) var(--layout-spacing);
    padding: calc(var(--layout-spacing) / 2) calc(var(--inline-spacing) * 4);
    border-inline-start: 3px solid var(--primary);
    border-radius: var(--border-radius);
    background: color-mix(in srgb, var(--primary) 6%, transparent);
  }
  .digest-heading {
    font-size: 0.95rem;
    color: var(--primary);
    margin-block: 0 calc(var(--layout-spacing) / 3);
  }
  .digest-body {
    font-size: 0.95rem;
  }

  .date-heading {
    font-size: 0.875rem;
    color: var(--muted);
    font-weight: 400;
    line-height: 1;
    margin-block: calc(var(--layout-spacing) * 0.75)
      calc(var(--layout-spacing) / 3);
    padding-inline-start: calc(var(--inline-spacing) * 2);
    border-inline-start: 3px solid var(--primary);
    white-space: nowrap;
  }
  .date-heading .count {
    font-size: 0.7rem;
    color: var(--very-muted);
    margin-inline-start: calc(var(--inline-spacing) * 3);
  }
  section:first-of-type .date-heading {
    margin-block-start: calc(var(--layout-spacing) / 3);
  }

  article {
    padding-block: 0;
  }
  article + article {
    border-block-start: 1px dashed var(--very-muted);
  }

  details {
    padding-block: calc(var(--layout-spacing) / 3);
  }
  summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: calc(var(--inline-spacing) * 3);
    font-size: 0.95rem;
    transition: var(--transition);
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::before {
    content: "+";
    color: var(--primary);
    font-weight: 700;
    flex-shrink: 0;
    width: 1ch;
    text-align: center;
  }
  details[open] summary::before {
    content: "−";
  }
  summary:hover {
    color: var(--primary);
  }

  .details-body {
    margin-inline-start: calc(1ch + var(--inline-spacing) * 3);
  }
  .pr-link-row {
    display: flex;
    justify-content: flex-end;
    margin-block-start: calc(var(--layout-spacing) / 3);
  }

  nav.pagination {
    display: flex;
    gap: calc(var(--inline-spacing) * 3);
    justify-content: center;
    align-items: center;
    margin-block-start: calc(var(--layout-spacing) * 1.5);
    font-size: 0.875rem;
  }
  nav.pagination a {
    text-decoration: none;
    padding: var(--inline-spacing) calc(var(--inline-spacing) * 4);
    border: 1px solid var(--primary);
    border-radius: var(--border-radius);
    transition: var(--transition);
  }
  nav.pagination a:hover {
    background-color: var(--primary);
    color: var(--background);
  }
  nav.pagination .page-indicator {
    color: var(--muted);
  }
</style>

<Layout title="I Shipped..." description={description}>
  <Nav />
  <main class="mono">
    <h1 class="title">I Shipped...</h1>
    {
      digest && (
        <section class="digest">
          <h2 class="digest-heading mono">{digestLabel}</h2>
          <div class="digest-body">
            {DigestContent ? (
              <DigestContent />
            ) : (
              <Fragment set:html={digestHtml} />
            )}
          </div>
        </section>
      )
    }
    {
      Object.entries(groupedByDate).map(async ([dateKey, items]) => (
        <section>
          <h2 class="date-heading mono">
            {dateKey}<span class="count">
              ({items.length} {items.length === 1 ? "PR" : "PRs"})
            </span>
          </h2>

          {items.map(async (item) => {
            const Content = item.entry ? (await render(item.entry)).Content : null;
            const bodyHtml: string = item.entry
              ? ""
              : await marked.parse(item.markdown ?? "");
            return (
              <article>
                <details>
                  <summary>{item.summary}</summary>
                  <div class="details-body">
                    {Content ? (
                      <Content />
                    ) : (
                      <Fragment set:html={bodyHtml} />
                    )}
                    <div class="pr-link-row">
                      <GitHubLink repo={item.repo} pr={item.prNumber} />
                    </div>
                  </div>
                </details>
              </article>
            );
          })}
        </section>
      ))
    }

    {
      totalPages > 1 && (
        <nav class="pagination">
          {currentPage > 1 && (
            <a
              href={
                currentPage === 2
                  ? "/i-shipped/"
                  : `/i-shipped/${currentPage - 1}/`
              }
            >
              Prev
            </a>
          )}
          <span class="page-indicator">
            Page {currentPage} of {totalPages}
          </span>
          {currentPage < totalPages && (
            <a href={`/i-shipped/${currentPage + 1}/`}>Next</a>
          )}
        </nav>
      )
    }
  </main>
</Layout>
