---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Default.astro";
import Smidgeon from "../../components/Smidgeon.astro";
import Nav from "../../components/NewNav.astro";
import { fetchSmidgeons, safe, type SmidgeonView } from "../../lib/pds";

const ITEMS_PER_PAGE = 20;

// Prefer the PDS (es.joeinn.smidgeon); fall back to the local content collection
// when the fetch fails or returns nothing, so the build stays green throughout
// the migration. Only past-dated smidgeons, newest first — same as before.
async function loadSmidgeons(): Promise<SmidgeonView[]> {
  const now = new Date();
  const isPast = (d: Date) => d instanceof Date && !isNaN(d.getTime()) && d < now;

  const pds = (await safe(fetchSmidgeons(), [] as SmidgeonView[])).filter((s) =>
    isPast(s.created),
  );
  if (pds.length > 0) {
    return pds.sort((a, b) => b.created.getTime() - a.created.getTime());
  }

  const local = (await getCollection("smidgeons", ({ data }) => data.created < now)).map(
    (e) => ({ summary: e.data.summary, body: e.body, created: e.data.created }),
  );
  return local.sort((a, b) => b.created.getTime() - a.created.getTime());
}

const { page } = Astro.params;
const currentPage = page ? parseInt(page as string) : 1;
const allSmidgeons = await loadSmidgeons();
const totalPages = Math.ceil(allSmidgeons.length / ITEMS_PER_PAGE);
const paginatedSmidgeons = allSmidgeons.slice(
  (currentPage - 1) * ITEMS_PER_PAGE,
  currentPage * ITEMS_PER_PAGE,
);

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 20;
  const now = new Date();
  const isPast = (d: Date) => d instanceof Date && !isNaN(d.getTime()) && d < now;

  // Mirror the body's source selection so the emitted page count matches.
  const pdsCount = (await safe(fetchSmidgeons(), [] as SmidgeonView[])).filter((s) =>
    isPast(s.created),
  ).length;
  const count =
    pdsCount > 0
      ? pdsCount
      : (await getCollection("smidgeons", ({ data }) => data.created < now)).length;
  const totalPages = Math.ceil(count / ITEMS_PER_PAGE);

  return [
    { params: { page: undefined } }, // Handle /smidgeons
    ...Array.from({ length: totalPages }, (_, i) => ({
      params: { page: String(i + 1) },
    })),
  ];
}

const description =
  "Smidgeons from Joe Innes — short-form notes, snippets, and passing thoughts, inspired by Maggie Appleton.";
---

<style>
  nav {
    display: flex;
    gap: var(--inline-spacing);
    justify-content: center;
    align-items: center;
    margin-block: var(--layout-spacing);
  }

  h1 {
    margin-block-end: 0;
  }
  h2 {
    font-size: 1em;
    font-weight: 400;
    margin-block-start: 0;
    margin-block-end: var(--layout-spacing);
  }
</style>

<Layout title="Joe Innes | Smidgeons" description={description}>
  <Nav />
  <main>
    <h1 class="title">Smidgeons</h1>
    <h2>
      Inspired by <a href="https://maggieappleton.com/smidgeons" target="_blank"
        >Maggie Appleton's smidgeons</a
      >
    </h2>

    <div class="divide-y text-lg divide-primary-100">
      {
        paginatedSmidgeons.map((smidgeon) => {
          return <Smidgeon smidgeon={smidgeon} />;
        })
      }
    </div>

    {
      totalPages > 1 && (
        <nav>
          {currentPage > 1 && (
            <a
              href={
                currentPage === 2
                  ? "/smidgeons/"
                  : `/smidgeons/${currentPage - 1}/`
              }
            >
              Prev
            </a>
          )}
          <span>
            Page {currentPage} of {totalPages}
          </span>
          {currentPage < totalPages && (
            <a href={`/smidgeons/${currentPage + 1}/`}>Next</a>
          )}
        </nav>
      )
    }
  </main>
</Layout>
