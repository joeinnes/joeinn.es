---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Default.astro";
import Nav from "../../components/NewNav.astro";
import Signature from "../../components/Signature.svelte";
import Comments from "@bryanguffey/astro-standard-site/components/Comments.astro";
import { generateDocumentLinkTag } from "@bryanguffey/astro-standard-site";
import manifest from "../../../standard-site.manifest.json";
import siteConfig from "../../../standard-site.config.json";
import PostBody from "../../components/PostBody.astro";
import { fetchBlogPost, safe } from "../../lib/pds";

const { slug } = Astro.params;
if (!slug) throw new Error("Slug not found");

// Prefer the PDS record (es.joeinn.blog.post, rkey = slug); fall back to the MDX
// entry for posts not yet migrated (the hand-migrate set) and drafts.
const record = await safe(fetchBlogPost(slug), null);
const entry = record ? null : await getEntry("posts", slug);
if (!record && !entry) throw new Error("No post found for this slug");

// One normalised shape, whichever source we have.
const post = record ?? {
  slug,
  title: entry!.data.title,
  date: new Date(entry!.data.date),
  dateUpdated: entry!.data.date_updated ? new Date(entry!.data.date_updated) : undefined,
  excerpt: entry!.data.excerpt as string | undefined,
  pageBg: entry!.data.page_bg as string | undefined,
  featuredImage: entry!.data.featured_image as string | undefined,
  body: "",
};
const bskyPostUri = entry?.data.bskyPostUri;
const Content = entry ? (await render(entry)).Content : null;

// standard.site verification: if this post has a published document record, emit
// a <link> pointing back to it.
const docRecord = manifest.documents?.[`posts:${slug}`];
const docRkey = docRecord?.docUri.split("/").pop();
const linkTag = docRkey
  ? generateDocumentLinkTag({ did: siteConfig.did, documentRkey: docRkey })
  : null;
const canonicalUrl = `${siteConfig.siteUrl}/blog/${slug}`;

const pageUrl = new URL(`/blog/${slug}`, Astro.site).href;
const absoluteImage = post.featuredImage
  ? new URL(post.featuredImage, Astro.site).href
  : undefined;

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  datePublished: post.date.toISOString(),
  dateModified: (post.dateUpdated ?? post.date).toISOString(),
  author: {
    "@type": "Person",
    name: "Joe Innes",
  },
  mainEntityOfPage: pageUrl,
  ...(absoluteImage ? { image: absoluteImage } : {}),
  ...(post.excerpt ? { description: post.excerpt } : {}),
};

// Generate a page for every post slug (records + any un-migrated MDX), so URLs
// stay byte-identical.
export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({ params: { slug: post.slug } }));
}
---

<style>
  p img {
    margin-block-end: var(--layout-spacing);
  }
</style>
<Layout
  title={post.title}
  bg={post.pageBg}
  description={post.excerpt}
  image={post.featuredImage}
  type="article"
>
  {linkTag && <Fragment slot="head" set:html={linkTag} />}
  <script
    type="application/ld+json"
    set:html={JSON.stringify(blogPostingJsonLd)}
    slot="head"
  />
  <Nav />
  <main>
    <hgroup class="content meta">
      <h1 class="title" transition:name={`post-title-${post.slug}`}>
        {post.title}
      </h1>
      <small
        >{
          new Intl.DateTimeFormat("en-GB", {
            dateStyle: "full",
            timeStyle: "short",
            hour12: true,
          }).format(post.date)
        }.</small
      >
    </hgroup>
    {
      post.featuredImage && (
        <div>
          <img
            alt={post.title}
            src={post.featuredImage}
            width="1200"
            height="675"
            decoding="async"
            loading="eager"
            fetchpriority="high"
            style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; margin-block-end: var(--layout-spacing);"
          />
        </div>
      )
    }

    <article class="content">
      {record ? <PostBody body={record.body} /> : <Content />}
      <div
        style="color: var(--primary); width: 30% !important; margin-inline-start: auto; margin-block: var(--layout-spacing);"
      >
        <Signature client:load />
      </div>
    </article>
    {
      bskyPostUri && (
        <Comments
          bskyPostUri={bskyPostUri}
          canonicalUrl={canonicalUrl}
          maxDepth={3}
        />
      )
    }
  </main>
</Layout>
