---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Default.astro";
import Nav from "../../components/NewNav.astro";

const posts = await getCollection("posts");
const now = new Date();
const filteredPosts = await getCollection("posts", ({ data }) => {
  return !data.draft && new Date(data.date) < now;
});
const dateSort = (a, b) => new Date(b.data.date) - new Date(a.data.date);
---

<style>
  .title {
    margin-block-end: var(--layout-spacing);
  }
  a:has(article) {
    display: block;
    padding-block: var(--layout-spacing);
    color: var(--foreground);
    border-bottom: 1px solid var(--primary);
    font-weight: normal;
    text-decoration: none;
  }
  a:has(article):hover {
    background-color: color-mix(
      in hsl,
      var(--primary) 4%,
      var(--background) 96%
    );
  }

  h2 {
    display: inline-block;
    margin-block-end: calc(var(--layout-spacing) / 2);
  }

  .post-meta {
    display: block;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--font-mono);
    margin-block-end: calc(var(--inline-spacing) * 2);
    letter-spacing: 0.03em;
  }

  .search {
    position: relative;
    display: block;
    margin-block-end: var(--layout-spacing);
  }
  .search svg {
    position: absolute;
    inset-inline-start: calc(var(--inline-spacing) * 2);
    inset-block-start: 50%;
    transform: translateY(-50%);
    width: auto;
    height: 1.1em;
    stroke: var(--muted);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    pointer-events: none;
  }
  .search input {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid var(--very-muted);
    padding: calc(var(--inline-spacing) * 2)
      calc(var(--inline-spacing) * 2)
      calc(var(--inline-spacing) * 2)
      calc(var(--inline-spacing) * 6 + 1.1em);
    outline: none;
    transition: border-color 200ms ease;
  }
  .search input:focus {
    border-bottom-color: var(--primary);
  }
</style>

<Layout title="Joe Innes | Blog">
  <Nav />
  <main>
    <h1 class="title">Joe Innes's Blog</h1>

    <label class="search">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="m21 21-4.34-4.34"></path><circle cx="11" cy="11" r="8"
        ></circle></svg
      >
      <input
        id="search"
        type="text"
        placeholder={`Search (e.g.: ${posts[Math.floor(Math.random() * posts.length)]?.data.title})`}
      />
    </label>

    <div
      class="relative flex flex-col justify-center w-full px-4 pb-8 mx-auto prose md:prose-xl max-md:max-w-full"
    >
      <div
        class="flex flex-col gap-8 overflow-hidden divide-y-2 text-ellipsis divide-primary-100"
        style="--border-bottom-hover: black"
      >
        <div id="no-results" class="border-0" style="display: none;">
          Hmm, no results for that, try something else?
        </div>

        {
          filteredPosts.length &&
            filteredPosts.sort(dateSort).map((post) => (
              <a href={`/blog/${post?.slug}`}>
                <article
                  style={`--border-colour: ${post?.data.page_bg || "black"};`}
                  data-title={post.data.title.toLowerCase()}
                >
                  <time class="post-meta" datetime={new Date(post.data.date).toISOString()}>
                    {new Date(post.data.date).toLocaleDateString("en-GB", {
                      day: "numeric",
                      month: "long",
                      year: "numeric",
                    })}
                  </time>
                  <div>
                    <h2 transition:name={`post-title-${post.slug}`}>{post?.data.title}</h2>
                  </div>

                  {post?.data.excerpt ||
                    "No excerpt available for this post. Click and see what's inside!"}
                </article>
              </a>
            ))
        }
      </div>
    </div>
    <script>
      function initBlogSearch() {
        const input = document.getElementById("search");
        if (!input || input.dataset.bound === "true") return;
        input.dataset.bound = "true";

        const posts = document.querySelectorAll("article");
        const noResults = document.getElementById("no-results");

        input.addEventListener("input", () => {
          if (!input.value) {
            posts.forEach((post) => {
              post.parentNode.style.display = "block";
            });
            if (noResults) noResults.style.display = "none";
            return;
          }
          const query = input.value.toLowerCase();
          let showingPosts = 0;
          posts.forEach((post) => {
            const title = post.dataset.title;
            const matches = title.includes(query);
            post.parentNode.style.display = matches ? "block" : "none";
            if (matches) showingPosts += 1;
          });

          if (noResults) {
            noResults.style.display = showingPosts ? "none" : "block";
          }
        });
      }

      document.addEventListener("astro:page-load", initBlogSearch);
    </script>
  </main>
</Layout>

<style lang="postcss">
	article h2 {
		text-decoration: none;
		background-image: linear-gradient(var(--border-colour), var(--border-colour));
		background-position: 0% 100%;
		background-repeat: no-repeat;
		background-size: 0% 0.3rem;
		transition: background-size 0.3s;
	}

	article:hover h2,
	article:focus h2 {
		background-size: 100% 0.3rem;
	}
</style>
